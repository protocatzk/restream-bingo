---
import {
  DEFAULT_CONFIG,
  DEFAULT_PHRASES,
  type BingoConfig,
} from '../lib/bingo';

interface Props {
  brand?: string;
  subtitle?: string;
  /** Named preset id (e.g. dkm) – skips home localStorage */
  presetId?: string;
  /** Fixed board config from a preset page */
  presetConfig?: BingoConfig;
  /** Precomputed share token for the preset (optional display) */
  shareToken?: string;
  /** Lock setup: no reshuffle / no phrase edits, clean share path */
  locked?: boolean;
}

const {
  brand = 'Restream Bingo',
  subtitle = 'Einstellbar · teilbar · statisch deploybar',
  presetId,
  presetConfig,
  shareToken = '',
  locked = false,
} = Astro.props;

const bootConfig: BingoConfig = presetConfig
  ? {
      ...presetConfig,
      phrases: [...presetConfig.phrases],
    }
  : { ...DEFAULT_CONFIG, phrases: [...DEFAULT_PHRASES] };

const initialPhrases = bootConfig.phrases.join('\n');
const defaultTitle = bootConfig.title;
const defaultSize = bootConfig.size;
const defaultSeed = bootConfig.seed ?? '';
const defaultFree = bootConfig.freeCenter;
const presetJson = JSON.stringify(bootConfig);
---

<div
  class="app"
  id="bingo-app"
  data-base={import.meta.env.BASE_URL}
  data-preset-id={presetId ?? ''}
  data-preset={presetConfig ? presetJson : ''}
  data-share-token={shareToken}
  data-locked={locked ? '1' : '0'}
>
  <header class="header">
    <div>
      <h1>{brand}</h1>
      <p class="subtitle">{subtitle}</p>
    </div>
    <div class="btn-row">
      {
        !locked && (
          <button type="button" class="btn" id="btn-settings" aria-expanded="true">
            Einstellungen
          </button>
        )
      }
      {
        locked ? (
          <button type="button" class="btn" id="btn-clear-header">Markierungen löschen</button>
        ) : null
      }
      <button type="button" class="btn btn-primary" id="btn-new">
        {locked ? 'Board zurücksetzen' : 'Neues Board'}
      </button>
      {
        locked && (
          <button type="button" class="btn" id="btn-copy-link-header">Link kopieren</button>
        )
      }
    </div>
  </header>

  {
    !locked ? (
      <section class="panel" id="settings-panel" aria-label="Einstellungen">
        <div class="tabs" role="tablist">
          <button type="button" class="tab active" data-tab="setup" role="tab">Setup</button>
          <button type="button" class="tab" data-tab="share" role="tab">Teilen</button>
        </div>

        <div id="tab-setup">
          <div class="field">
            <label for="cfg-title">Titel</label>
            <input
              type="text"
              id="cfg-title"
              value={defaultTitle}
              maxlength="80"
              autocomplete="off"
            />
          </div>

          <div class="field-row">
            <div class="field">
              <label for="cfg-size">Größe</label>
              <select id="cfg-size">
                {[3, 4, 5, 6, 7].map((n) => (
                  <option value={n} selected={n === defaultSize}>
                    {n}×{n}
                    {n === 5 ? ' (klassisch)' : ''}
                  </option>
                ))}
              </select>
            </div>
            <div class="field checkbox-field">
              <input type="checkbox" id="cfg-free" checked={defaultFree} />
              <label for="cfg-free">Freies Mittelfeld</label>
            </div>
          </div>

          <div class="field">
            <label for="cfg-seed">Seed (optional)</label>
            <input
              type="text"
              id="cfg-seed"
              value={defaultSeed}
              placeholder="z.B. stream-2026-07-19"
              autocomplete="off"
            />
            <p class="field-hint">Gleicher Seed + gleiche Phrasen → gleiches Board für alle.</p>
          </div>

          <div class="field">
            <label for="cfg-phrases">Phrasen (eine pro Zeile)</label>
            <textarea id="cfg-phrases" spellcheck="false">{initialPhrases}</textarea>
            <p class="field-hint" id="phrase-count"></p>
          </div>

          <div class="btn-row">
            <button type="button" class="btn btn-primary" id="btn-apply">
              Übernehmen &amp; mischen
            </button>
            <button type="button" class="btn" id="btn-reset-phrases">Standard-Phrasen</button>
          </div>
        </div>

        <div id="tab-share" class="hidden">
          <p class="field-hint" style="margin-bottom: 0.75rem">
            Kurzer Link mit Konfiguration (ohne Markierungen). Standard-Phrasen werden weggelassen
            und komprimiert.
          </p>
          <div class="btn-row">
            <button type="button" class="btn btn-primary" id="btn-copy-link">Link kopieren</button>
            <button type="button" class="btn" id="btn-copy-config">Config-JSON kopieren</button>
          </div>
          <div class="share-box" id="share-url" aria-live="polite">—</div>
        </div>
      </section>
    ) : (
      <section class="panel share-slim" aria-label="Teilen">
        <p class="field-hint" style="margin: 0 0 0.6rem">
          Gleicher Link für alle – Board &amp; Seed sind fest.
        </p>
        <div class="btn-row">
          <button type="button" class="btn btn-primary" id="btn-copy-link">Link kopieren</button>
        </div>
        <div class="share-box" id="share-url" aria-live="polite">—</div>
      </section>
    )
  }

  <section class="panel" aria-label="Bingo-Board">
    <h2 class="bingo-title" id="board-title">{defaultTitle}</h2>
    <div
      class="bingo-board"
      id="board"
      role="grid"
      aria-label="Bingo-Felder"
      style={`grid-template-columns: repeat(${defaultSize}, 1fr);`}
    >
    </div>
    <div class="status-bar">
      <span class="status-message" id="status">Felder antippen zum Markieren</span>
      <button type="button" class="btn btn-ghost hidden" id="btn-clear">
        Markierungen löschen
      </button>
    </div>
  </section>

  <footer class="footer">
    {
      presetId ? (
        <>
          <a href={import.meta.env.BASE_URL}>← Start</a>
          {' · '}
        </>
      ) : null
    }
    Astro · Static · Vercel / GitHub Pages
  </footer>
</div>

<script>
  import {
    DEFAULT_CONFIG,
    DEFAULT_PHRASES,
    buildBoard,
    clampSize,
    decodeConfig,
    encodeConfig,
    findWin,
    neededCells,
    parsePhrases,
    type BingoCell,
    type BingoConfig,
  } from '../lib/bingo';

  const root = document.getElementById('bingo-app')!;
  const base = root.dataset.base || '/';
  const presetId = root.dataset.presetId || '';
  const locked = root.dataset.locked === '1';
  const bakedToken = root.dataset.shareToken || '';

  let presetConfig: BingoConfig | null = null;
  try {
    if (root.dataset.preset) {
      presetConfig = JSON.parse(root.dataset.preset) as BingoConfig;
    }
  } catch {
    presetConfig = null;
  }

  const el = {
    settingsPanel: document.getElementById('settings-panel'),
    btnSettings: document.getElementById('btn-settings'),
    btnNew: document.getElementById('btn-new')!,
    btnApply: document.getElementById('btn-apply'),
    btnResetPhrases: document.getElementById('btn-reset-phrases'),
    btnCopyLink: document.getElementById('btn-copy-link')!,
    btnCopyLinkHeader: document.getElementById('btn-copy-link-header'),
    btnCopyConfig: document.getElementById('btn-copy-config'),
    btnClear: document.getElementById('btn-clear')!,
    btnClearHeader: document.getElementById('btn-clear-header'),
    title: document.getElementById('cfg-title') as HTMLInputElement | null,
    size: document.getElementById('cfg-size') as HTMLSelectElement | null,
    free: document.getElementById('cfg-free') as HTMLInputElement | null,
    seed: document.getElementById('cfg-seed') as HTMLInputElement | null,
    phrases: document.getElementById('cfg-phrases') as HTMLTextAreaElement | null,
    phraseCount: document.getElementById('phrase-count'),
    boardTitle: document.getElementById('board-title')!,
    board: document.getElementById('board')!,
    status: document.getElementById('status')!,
    shareUrl: document.getElementById('share-url')!,
    tabSetup: document.getElementById('tab-setup'),
    tabShare: document.getElementById('tab-share'),
  };

  let config: BingoConfig = presetConfig
    ? { ...presetConfig, phrases: [...presetConfig.phrases] }
    : { ...DEFAULT_CONFIG, phrases: [...DEFAULT_PHRASES] };
  let cells: BingoCell[] = [];
  let marked: boolean[] = [];
  let winLine: number[] | null = null;

  function storageKey(): string {
    return presetId ? `bingo-preset:${presetId}` : 'bingo-config';
  }

  function marksKey(): string {
    return presetId ? `bingo-marks:${presetId}` : 'bingo-marks';
  }

  function readForm(): BingoConfig {
    if (presetConfig && locked) {
      return { ...presetConfig, phrases: [...presetConfig.phrases] };
    }
    return {
      title: el.title?.value.trim() || DEFAULT_CONFIG.title,
      size: clampSize(Number(el.size?.value) || 5),
      freeCenter: el.free?.checked ?? true,
      phrases: parsePhrases(el.phrases?.value ?? ''),
      seed: el.seed?.value.trim() || undefined,
    };
  }

  function writeForm(c: BingoConfig) {
    if (!el.title) return;
    el.title.value = c.title;
    if (el.size) el.size.value = String(c.size);
    if (el.free) el.free.checked = c.freeCenter;
    if (el.seed) el.seed.value = c.seed || '';
    if (el.phrases) el.phrases.value = c.phrases.join('\n');
    updatePhraseHint();
  }

  function updatePhraseHint() {
    if (!el.phraseCount || !el.phrases) return;
    const n = parsePhrases(el.phrases.value).length;
    const size = clampSize(Number(el.size?.value) || 5);
    const need = neededCells(size, el.free?.checked ?? true);
    el.phraseCount.textContent =
      n >= need
        ? `${n} Phrasen · ${need} benötigt für ${size}×${size}`
        : `${n} Phrasen · ${need} benötigt (wird zyklisch aufgefüllt)`;
  }

  async function updateShareUrl() {
    // Locked presets share the clean path (e.g. /dkm) – config is baked in
    if (locked && presetId) {
      const url = new URL(window.location.href);
      url.search = '';
      url.hash = '';
      // normalize trailing slash for BASE_PATH
      const path = url.pathname.endsWith('/') ? url.pathname : `${url.pathname}/`;
      url.pathname = path;
      el.shareUrl.textContent = url.toString();
      return;
    }

    const token = bakedToken || (await encodeConfig(config));
    const url = new URL(window.location.href);
    url.search = '';
    const path =
      url.pathname.endsWith('/') || base === '/' ? url.pathname : `${url.pathname}/`;
    url.pathname = path;
    url.hash = token;
    el.shareUrl.textContent = url.toString();
  }

  function setStatus(msg: string, isWin = false) {
    el.status.textContent = msg;
    el.status.classList.toggle('win', isWin);
  }

  function saveMarks() {
    try {
      localStorage.setItem(marksKey(), JSON.stringify(marked));
    } catch {
      /* ignore */
    }
  }

  function loadMarks(expectedLen: number): boolean[] | null {
    try {
      const raw = localStorage.getItem(marksKey());
      if (!raw) return null;
      const arr = JSON.parse(raw) as boolean[];
      if (!Array.isArray(arr) || arr.length !== expectedLen) return null;
      return arr.map(Boolean);
    } catch {
      return null;
    }
  }

  function renderBoard() {
    el.boardTitle.textContent = config.title;
    el.board.style.gridTemplateColumns = `repeat(${config.size}, 1fr)`;
    el.board.replaceChildren();

    cells.forEach((cell, i) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'bingo-cell';
      btn.dataset.index = String(i);
      btn.setAttribute('role', 'gridcell');
      btn.setAttribute('aria-pressed', marked[i] ? 'true' : 'false');
      btn.textContent = cell.text;
      if (cell.free) btn.classList.add('free');
      if (marked[i]) btn.classList.add('marked');
      if (winLine?.includes(i)) btn.classList.add('win-line');
      btn.addEventListener('click', () => toggleCell(i));
      el.board.appendChild(btn);
    });

    el.btnClear.classList.toggle('hidden', !marked.some(Boolean));
  }

  function confettiLite() {
    const n = 28;
    for (let i = 0; i < n; i++) {
      const d = document.createElement('div');
      d.style.cssText = `
        position:fixed;top:-12px;left:${Math.random() * 100}vw;
        width:${6 + Math.random() * 6}px;height:${6 + Math.random() * 6}px;
        background:hsl(${250 + Math.random() * 90},85%,62%);
        border-radius:2px;z-index:9999;pointer-events:none;
        animation:fall ${1.1 + Math.random()}s linear forwards;
      `;
      document.body.appendChild(d);
      setTimeout(() => d.remove(), 2300);
    }
    if (!document.getElementById('confetti-style')) {
      const s = document.createElement('style');
      s.id = 'confetti-style';
      s.textContent =
        '@keyframes fall{to{transform:translateY(105vh) rotate(720deg);opacity:0}}';
      document.head.appendChild(s);
    }
  }

  function checkWin() {
    winLine = findWin(marked, config.size);
    if (winLine) {
      setStatus('🎉 BINGO!', true);
      confettiLite();
    } else {
      const count = marked.filter(Boolean).length;
      setStatus(count ? `${count} markiert · Felder antippen` : 'Felder antippen zum Markieren');
    }
    renderBoard();
    saveMarks();
  }

  function toggleCell(i: number) {
    if (winLine) return;
    marked[i] = !marked[i];
    checkWin();
  }

  function persist(c: BingoConfig) {
    if (locked) return;
    try {
      localStorage.setItem(storageKey(), JSON.stringify(c));
    } catch {
      /* ignore */
    }
  }

  function newBoard(from?: BingoConfig, restoreMarks = false) {
    config = from ?? readForm();
    config = {
      ...config,
      size: clampSize(config.size),
      phrases: config.phrases.length ? config.phrases : [...DEFAULT_PHRASES],
    };
    cells = buildBoard(config);
    const restored = restoreMarks ? loadMarks(cells.length) : null;
    marked = restored ?? cells.map((c) => c.free);
    winLine = null;
    writeForm(config);
    void updateShareUrl();
    checkWin();
    persist({ ...config, seed: config.seed });
  }

  function clearMarks() {
    marked = cells.map((c) => c.free);
    winLine = null;
    checkWin();
  }

  // ── Tabs (home only) ────────────────────────────────────────────────────

  root.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      root.querySelectorAll('.tab').forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      const name = (tab as HTMLElement).dataset.tab;
      el.tabSetup?.classList.toggle('hidden', name !== 'setup');
      el.tabShare?.classList.toggle('hidden', name !== 'share');
      if (name === 'share') void updateShareUrl();
    });
  });

  el.btnSettings?.addEventListener('click', () => {
    if (!el.settingsPanel) return;
    const hidden = el.settingsPanel.classList.toggle('hidden');
    el.btnSettings?.setAttribute('aria-expanded', String(!hidden));
  });

  el.btnApply?.addEventListener('click', () => newBoard());

  el.btnNew.addEventListener('click', () => {
    if (locked && presetConfig) {
      // Same board, clear marks
      clearMarks();
      setStatus('Board zurückgesetzt');
      return;
    }
    const c = readForm();
    if (c.seed) {
      newBoard(c);
      return;
    }
    const ephemeral = { ...c, seed: String(Date.now()) };
    config = ephemeral;
    cells = buildBoard(ephemeral);
    marked = cells.map((x) => x.free);
    winLine = null;
    el.boardTitle.textContent = config.title;
    void updateShareUrl();
    checkWin();
    persist({ ...c, seed: undefined });
  });

  el.btnResetPhrases?.addEventListener('click', () => {
    if (el.phrases) el.phrases.value = DEFAULT_PHRASES.join('\n');
    updatePhraseHint();
  });

  el.btnClear.addEventListener('click', clearMarks);
  el.btnClearHeader?.addEventListener('click', clearMarks);

  el.phrases?.addEventListener('input', updatePhraseHint);
  el.size?.addEventListener('change', updatePhraseHint);
  el.free?.addEventListener('change', updatePhraseHint);

  async function copyText(text: string, ok: string) {
    try {
      await navigator.clipboard.writeText(text);
      setStatus(ok);
    } catch {
      setStatus('Kopieren fehlgeschlagen – Text manuell markieren');
    }
  }

  async function copyShareLink() {
    await updateShareUrl();
    await copyText(el.shareUrl.textContent || '', 'Link kopiert!');
  }

  el.btnCopyLink.addEventListener('click', () => void copyShareLink());
  el.btnCopyLinkHeader?.addEventListener('click', () => void copyShareLink());

  el.btnCopyConfig?.addEventListener('click', () => {
    void copyText(JSON.stringify(config, null, 2), 'Config-JSON kopiert!');
  });

  function readShareToken(): string | null {
    const hash = window.location.hash.replace(/^#/, '').trim();
    if (hash) {
      if (hash.startsWith('b=')) return decodeURIComponent(hash.slice(2));
      if (hash.startsWith('2.') || hash.startsWith('3.')) return hash;
      if (hash.length > 8) return hash;
    }
    const params = new URLSearchParams(window.location.search);
    return params.get('b') || params.get('c');
  }

  async function boot() {
    // Preset pages always load their fixed board (marks may restore)
    if (presetConfig) {
      newBoard(
        { ...presetConfig, phrases: [...presetConfig.phrases] },
        true,
      );
      return;
    }

    const token = readShareToken();
    if (token) {
      const decoded = await decodeConfig(token);
      if (decoded) {
        newBoard(decoded);
        return;
      }
    }

    try {
      const raw = localStorage.getItem(storageKey());
      if (raw) {
        const saved = JSON.parse(raw) as BingoConfig;
        if (saved && Array.isArray(saved.phrases)) {
          newBoard({
            title: saved.title || DEFAULT_CONFIG.title,
            size: clampSize(Number(saved.size) || 5),
            freeCenter: !!saved.freeCenter,
            phrases: saved.phrases.length ? saved.phrases : [...DEFAULT_PHRASES],
            seed: saved.seed,
          });
          return;
        }
      }
    } catch {
      /* ignore */
    }

    newBoard({ ...DEFAULT_CONFIG, phrases: [...DEFAULT_PHRASES] });
  }

  void boot();
</script>
